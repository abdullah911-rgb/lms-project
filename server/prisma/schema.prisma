// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum InstructorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonType {
  VIDEO
  PDF
  TEXT
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum MeetingStatus {
  PENDING_APPROVAL
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
  REJECTED
}

enum AnnouncementTarget {
  ALL
  STUDENTS
  INSTRUCTORS
}

enum AnnouncementType {
  INFO
  WARNING
  ALERT
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum OTPPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethodType {
  BANK_TRANSFER
  EASYPAISA
  JAZZCASH
}

// ─── USER ────────────────────────────────────────────────────────────────────

model User {
  id                     String                   @id @default(uuid())
  name                   String
  email                  String                   @unique
  password               String
  role                   Role                     @default(STUDENT)
  avatar                 String?
  bio                    String?
  phone                  String?
  isVerified             Boolean                  @default(false)
  isActive               Boolean                  @default(true)
  // Instructor approval fields
  instructorApproval     InstructorApprovalStatus @default(APPROVED)
  instructorRejectedNote String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  // Relations
  refreshTokens        RefreshToken[]
  enrollments          Enrollment[]
  certificates         Certificate[]
  notifications        Notification[]
  attendance           Attendance[]
  otpVerifications     OTPVerification[]
  quizAttempts         QuizAttempt[]
  platformAnnouncements PlatformAnnouncement[] @relation("AdminAnnouncements")
  reviews              Review[]               @relation("StudentReviews")
  receivedReviews      Review[]               @relation("InstructorReviews")
  paymentRequests      PaymentRequest[]       @relation("StudentPayments")

  // Instructor specific
  courses         Course[]         @relation("InstructorCourses")
  zoomMeetings    ZoomMeeting[]    @relation("InstructorMeetings")
  announcements   Announcement[]   @relation("AuthoredAnnouncements")
  lessonProgress  LessonProgress[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─── REFRESH TOKEN ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── OTP VERIFICATION ────────────────────────────────────────────────────────

model OTPVerification {
  id        String     @id @default(uuid())
  email     String
  otp       String
  purpose   OTPPurpose
  expiresAt DateTime
  userId    String?
  createdAt DateTime   @default(now())

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([otp])
  @@map("otp_verifications")
}

// ─── CATEGORY ────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     Course[]

  @@index([slug])
  @@map("categories")
}

// ─── COURSE ──────────────────────────────────────────────────────────────────

model Course {
  id               String       @id @default(uuid())
  title            String
  slug             String       @unique
  description      String
  shortDescription String?
  thumbnail        String?
  categoryId       String
  instructorId     String
  status           CourseStatus @default(DRAFT)
  level            CourseLevel  @default(BEGINNER)
  price            Decimal      @default(0) @db.Decimal(10, 2)
  isFree           Boolean      @default(true)
  duration         Int?         // Total duration in minutes
  durationInMonths Int          @default(2) // 2, 4, or 6 months
  totalLessons     Int          @default(0)
  learningOutcomes String[]
  prerequisites    String[]
  language         String       @default("English")
  certificate      Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  pendingApproval  Boolean      @default(false)
  pendingEdits     Json?

  category         Category     @relation(fields: [categoryId], references: [id])
  instructor       User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  modules          Module[]
  enrollments      Enrollment[]
  zoomMeetings     ZoomMeeting[]
  announcements    Announcement[]
  certificates     Certificate[]
  resources        Resource[]
  reviews          Review[]
  paymentRequests  PaymentRequest[]

  @@index([slug])
  @@index([categoryId])
  @@index([instructorId])
  @@index([status])
  @@map("courses")
}

// ─── MODULE ──────────────────────────────────────────────────────────────────

model Module {
  id          String   @id @default(uuid())
  title       String
  description String?
  courseId    String
  order       Int
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  quiz        Quiz?

  @@index([courseId])
  @@map("modules")
}

// ─── LESSON ──────────────────────────────────────────────────────────────────

model Lesson {
  id          String     @id @default(uuid())
  title       String
  description String?
  moduleId    String
  type        LessonType @default(VIDEO)
  content     String?    // Text content or embed URL
  videoUrl    String?
  duration    Int?       // Duration in seconds
  order       Int
  isFree      Boolean    @default(false)
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  resources   Resource[]
  progress    LessonProgress[]

  @@index([moduleId])
  @@map("lessons")
}

// ─── RESOURCE ────────────────────────────────────────────────────────────────

model Resource {
  id        String   @id @default(uuid())
  name      String
  fileUrl   String
  fileType  String
  fileSize  Int?
  lessonId  String?
  courseId  String?
  createdAt DateTime @default(now())

  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([courseId])
  @@map("resources")
}

// ─── ENROLLMENT ──────────────────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(uuid())
  studentId   String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  progress    Float            @default(0) // Percentage 0-100
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  updatedAt   DateTime         @updatedAt

  student        User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@map("enrollments")
}

// ─── LESSON PROGRESS ─────────────────────────────────────────────────────────

model LessonProgress {
  id             String     @id @default(uuid())
  enrollmentId   String
  lessonId       String
  userId         String
  isCompleted    Boolean    @default(false)
  watchedSeconds Int        @default(0)
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson         Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@index([lessonId])
  @@map("lesson_progress")
}

// ─── QUIZ ─────────────────────────────────────────────────────────────────────

model Quiz {
  id          String       @id @default(uuid())
  moduleId    String       @unique
  title       String
  description String?
  passMark    Int          @default(60) // Percentage required to pass
  timeLimit   Int?         // Minutes — null = no limit
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]
  attempts    QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String       @id @default(uuid())
  quizId        String
  question      String
  type          QuestionType @default(SINGLE_CHOICE)
  options       Json         // Array of { id, text } objects
  correctAnswer Json         // Array of correct option IDs
  explanation   String?
  order         Int
  marks         Int          @default(1)
  createdAt     DateTime     @default(now())

  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id          String    @id @default(uuid())
  quizId      String
  userId      String
  answers     Json      // { questionId: [selectedOptionIds] }
  score       Float     // Percentage
  passed      Boolean
  timeTaken   Int?      // Seconds
  completedAt DateTime  @default(now())

  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@map("quiz_attempts")
}

// ─── ZOOM MEETING ─────────────────────────────────────────────────────────────

model ZoomMeeting {
  id           String        @id @default(uuid())
  courseId     String
  instructorId String
  meetingId    String?       @unique
  topic        String
  agenda       String?
  startTime    DateTime
  duration     Int           // Duration in minutes
  joinUrl      String?
  startUrl     String?
  password     String?
  status       MeetingStatus @default(PENDING_APPROVAL)
  rejectedNote String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor   User          @relation("InstructorMeetings", fields: [instructorId], references: [id])
  attendance   Attendance[]

  @@index([courseId])
  @@index([instructorId])
  @@index([status])
  @@map("zoom_meetings")
}

// ─── ATTENDANCE ──────────────────────────────────────────────────────────────

model Attendance {
  id        String      @id @default(uuid())
  meetingId String
  studentId String
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?
  duration  Int?        // Duration in minutes

  meeting   ZoomMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  student   User        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([meetingId, studentId])
  @@index([meetingId])
  @@index([studentId])
  @@map("attendance")
}

// ─── CERTIFICATE ─────────────────────────────────────────────────────────────

model Certificate {
  id               String   @id @default(uuid())
  studentId        String
  courseId         String
  issuedAt         DateTime @default(now())
  certificateUrl   String?
  verificationCode String   @unique @default(uuid())

  student          User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@index([verificationCode])
  @@map("certificates")
}

// ─── PLATFORM ANNOUNCEMENT ───────────────────────────────────────────────────

model PlatformAnnouncement {
  id         String           @id @default(uuid())
  title      String
  body       String
  type       AnnouncementType @default(INFO)
  target     AnnouncementTarget @default(ALL)
  isActive   Boolean          @default(true)
  authorId   String
  expiresAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  author     User             @relation("AdminAnnouncements", fields: [authorId], references: [id])

  @@index([isActive])
  @@index([authorId])
  @@map("platform_announcements")
}

// ─── ANNOUNCEMENT (course-level) ─────────────────────────────────────────────

model Announcement {
  id          String             @id @default(uuid())
  title       String
  body        String
  authorId    String
  courseId    String?            // null = platform-wide
  targetRole  AnnouncementTarget @default(ALL)
  isPublished Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  author      User               @relation("AuthoredAnnouncements", fields: [authorId], references: [id])
  course      Course?            @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([courseId])
  @@index([isPublished])
  @@map("announcements")
}

// ─── NOTIFICATION ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ─── REVIEW ──────────────────────────────────────────────────────────────────

model Review {
  id           String   @id @default(uuid())
  rating       Int      // 1 to 5
  comment      String
  studentId    String
  courseId     String?
  instructorId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student    User    @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
  course     Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor User?   @relation("InstructorReviews", fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([courseId])
  @@index([instructorId])
  @@map("reviews")
}

// ─── PAYMENT METHOD ───────────────────────────────────────────────────────────

model PaymentMethod {
  id            String            @id @default(uuid())
  type          PaymentMethodType
  title         String            // e.g. "Meezan Bank", "Easypaisa"
  accountName   String
  accountNumber String
  instructions  String?           // Extra instructions for students
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("payment_methods")
}

// ─── PAYMENT REQUEST ──────────────────────────────────────────────────────────

model PaymentRequest {
  id              String        @id @default(uuid())
  studentId       String
  courseId        String
  amount          Decimal       @db.Decimal(10, 2)
  screenshotUrl   String        // Uploaded proof of payment
  transactionRef  String?       // Optional transaction ID from student
  status          PaymentStatus @default(PENDING)
  rejectedNote    String?
  reviewedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  student  User   @relation("StudentPayments",  fields: [studentId], references: [id], onDelete: Cascade)
  course   Course @relation(fields: [courseId],  references: [id],   onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@index([status])
  @@map("payment_requests")
}
